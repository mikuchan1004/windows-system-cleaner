<Window x:Class="WindowsSystemCleaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows 시스템 클리너" 
        Height="620" Width="430" 
        ResizeMode="NoResize" 
        Background="#0F0F0F"
        WindowStartupLocation="CenterScreen"
        Icon="Sparkle.png"
        Closed="Window_Closed">

    <Window.Resources>
        <Style x:Key="ModernStartButton" TargetType="Button">
            <Setter Property="Background" Value="#00ADB5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" CornerRadius="12" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#00CFD6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#008C93"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#333"/>
                                <Setter Property="Foreground" Value="#666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollThumbs" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="Rectangle" CornerRadius="3" Background="#333333" Margin="2,0" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Rectangle" Property="Background" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Background="Transparent" BorderThickness="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollThumbs}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Background="Transparent" BorderThickness="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    <RowDefinition Height="Auto"/> <RowDefinition Height="32"/>   </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#161616" Margin="25,20,25,10" CornerRadius="12" BorderBrush="#252525" BorderThickness="1">
            <StackPanel Margin="20,18">
                <TextBlock Text="⚡" FontSize="36" HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="20" Color="#00ADB5" ShadowDepth="0" Opacity="0.4"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="시스템 클리너" FontSize="22" FontWeight="Bold" Foreground="#00ADB5" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                <TextBlock Text="불필요한 임시 파일을 정리하여 장치를 최적화합니다." FontSize="11" Foreground="#666" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#161616" Margin="25,10" CornerRadius="12" BorderBrush="#252525" BorderThickness="1">
            <ScrollViewer x:Name="Scroller" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LogText" 
                           Foreground="#E0E0E0" 
                           FontFamily="Consolas" 
                           FontSize="12" 
                           LineHeight="20"
                           Margin="16,14" 
                           TextWrapping="Wrap" 
                           Text="안녕하세요! 시스템 최적화를 시작해볼까요?"/>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Background="#161616" Margin="25,10,25,15" CornerRadius="12" BorderBrush="#252525" BorderThickness="1">
            <StackPanel Margin="18">
                <Border Height="5" Background="#252525" CornerRadius="2.5" Margin="0,0,0,14" ClipToBounds="True">
                    <ProgressBar x:Name="PBar" Background="Transparent" Foreground="#00ADB5" BorderThickness="0" Minimum="0" Maximum="100"/>
                </Border>
                <Button x:Name="BtnStart" Content="✨ 원클릭 정리 시작" 
                        Height="50"
                        Style="{StaticResource ModernStartButton}"
                        Click="BtnStart_Click"/>
            </StackPanel>
        </Border>

        <StatusBar Grid.Row="3" Background="#0C0C0C" Foreground="#555" BorderThickness="0,1,0,0" BorderBrush="#1C1C1C">
            <StatusBarItem>
                <TextBlock x:Name="StatusMsg" Text="준비 완료" FontSize="11" Margin="15,0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
